<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="550.0" prefWidth="741.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="KaziTahmidAbtahi.FinanceOfficer.ManageBookingsController">
    <children>
        <Label layoutX="73.0" layoutY="42.0" text="Pending Booking Requests" textFill="#4943ac">
            <font>
                <Font name="System Bold" size="20.0" />
            </font>
        </Label>

        <Label layoutX="45.0" layoutY="100.0" text="Filter By Date Range:" />
        <DatePicker fx:id="filterStartDatePicker" layoutX="165.0" layoutY="96.0" prefWidth="130.0" promptText="Start Date" />
        <DatePicker fx:id="filterEndDatePicker" layoutX="314.0" layoutY="96.0" prefWidth="130.0" promptText="End Date" />

        <Label layoutX="45.0" layoutY="140.0" text="Payment Plan Type:" />
        <ComboBox fx:id="paymentPlanFilterCB" layoutX="155.0" layoutY="136.0" prefWidth="150.0" />

        <Button layoutX="332.0" layoutY="135.0" mnemonicParsing="false" onAction="#applyFiltersButtonOnAction" prefHeight="39.0" prefWidth="118.0" text="Apply Filters" />

        <TableView fx:id="pendingBookingsTableView" layoutX="45.0" layoutY="185.0" prefHeight="250.0" prefWidth="650.0">
            <columns>
                <TableColumn fx:id="bookingIdTC" prefWidth="75.0" text="Booking ID" />
                <TableColumn fx:id="clientNameTC" prefWidth="105.0" text="Client Name" />
                <TableColumn fx:id="propertyNameTC" prefWidth="110.0" text="Property Name" />
                <TableColumn fx:id="paymentPlanTC" prefWidth="120.0" text="Payment Plan" />
                <TableColumn fx:id="docStatusTC" prefWidth="140.0" text="Submission Status" />
                <TableColumn fx:id="requestDateTC" prefWidth="99.0" text="Request Date" />
            </columns>
        </TableView>

        <Button layoutX="60.0" layoutY="450.0" mnemonicParsing="false" onAction="#viewBookingDetailsButtonOnAction" prefHeight="30.0" prefWidth="150.0" text="View Booking Details" />

        <Label fx:id="feedbackLabel" layoutX="340.0" layoutY="443.0" prefHeight="74.0" prefWidth="332.0" style="-fx-background-color: light grey;" text="Feedback........." />
    </children>
</AnchorPane>
