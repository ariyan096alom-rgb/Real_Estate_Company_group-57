<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane fx:id="mainBorderPane" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="600.0" prefWidth="900.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="KaziTahmidAbtahi.FinanceOfficer.FinanceOfficerDashboardController">

    <left>
        <VBox prefHeight="600.0" prefWidth="180.0" style="-fx-background-color: #2c3e60;" BorderPane.alignment="TOP_RIGHT">
            <children>

                <Button mnemonicParsing="false" onAction="#pendingBookingsButtonOnAction" prefHeight="30.0" prefWidth="115.0" text="Pending Bookings">
                    <VBox.margin>
                        <Insets bottom="15.0" left="30.0" top="50.0" />
                    </VBox.margin>
                </Button>

                <Button mnemonicParsing="false" onAction="#verifyDocumentsButtonOnAction" prefHeight="19.0" prefWidth="118.0" text="Verify Documents">
                    <VBox.margin>
                        <Insets bottom="15.0" left="30.0" />
                    </VBox.margin>
                </Button>

                <Button mnemonicParsing="false" onAction="#approveRejectButtonOnAction" prefHeight="23.0" prefWidth="124.0" text="Approve / Reject">
                    <VBox.margin>
                        <Insets bottom="15.0" left="25.0" />
                    </VBox.margin>
                </Button>

                <Button mnemonicParsing="false" onAction="#generateInvoiceButtonOnAction" prefHeight="32.0" prefWidth="126.0" text="Generate Invoice">
                    <VBox.margin>
                        <Insets bottom="15.0" left="25.0" />
                    </VBox.margin>
                </Button>

                <Button mnemonicParsing="false" onAction="#paymentRecordsButtonOnAction" prefHeight="32.0" prefWidth="117.0" text="Record Payment">
                    <VBox.margin>
                        <Insets bottom="15.0" left="30.0" />
                    </VBox.margin>
                </Button>

                <Button mnemonicParsing="false" onAction="#processCancellationsButtonOnAction" prefHeight="30.0" prefWidth="132.0" text="Process Cancellations">
                    <VBox.margin>
                        <Insets bottom="15.0" left="25.0" />
                    </VBox.margin>
                </Button>

                <Button mnemonicParsing="false" onAction="#reportsButtonOnAction" prefHeight="30.0" prefWidth="130.0" text="Financial Reports">
                    <VBox.margin>
                        <Insets bottom="15.0" left="25.0" />
                    </VBox.margin>
                </Button>

                <Button mnemonicParsing="false" onAction="#signOutButtonOnAction" prefHeight="41.0" prefWidth="98.0" text="Sign Out">
                    <font>
                        <Font name="System Bold" size="12.0" />
                    </font>
                    <VBox.margin>
                        <Insets left="40.0" top="50.0" />
                    </VBox.margin>
                </Button>
            </children>
        </VBox>
    </left>

    <top>
        <AnchorPane prefHeight="50.0" prefWidth="900.0" style="-fx-background-color: #e0e0e0;" BorderPane.alignment="CENTER">
            <children>
                <Label layoutX="25.0" layoutY="10.0" text="Finance Officer Dashboard" textFill="#994040">
                    <font>
                        <Font name="System Bold" size="22.0" />
                    </font>
                </Label>
            </children>
        </AnchorPane>
    </top>

    <center>
        <AnchorPane fx:id="homeAnchorPane" prefHeight="550.0" prefWidth="720.0" BorderPane.alignment="CENTER">
            <children>
                <Label layoutX="50.0" layoutY="47.0" text="Dashboard Summary" textFill="#2f46b9">
                    <font>
                        <Font name="System Bold" size="22.0" />
                    </font>
                </Label>

                <Label layoutX="50.0" layoutY="91.0" text="Pending Booking Requests:">
                    <font>
                        <Font size="14.0" />
                    </font>
                </Label>
                <Label fx:id="pendingBookingsCountLabel" layoutX="250.0" layoutY="88.0" prefHeight="26.0" prefWidth="290.0" textFill="#b22b2b">
                    <font>
                        <Font name="System Bold" size="16.0" />
                    </font>
                </Label>

                <Label layoutX="50.0" layoutY="131.0" text="Total Pending Payments:">
                    <font>
                        <Font size="14.0" />
                    </font>
                </Label>
                <Label fx:id="pendingPaymentsAmountLabel" layoutX="250.0" layoutY="128.0" prefHeight="26.0" prefWidth="283.0" textFill="#b22b2b">
                    <font>
                        <Font name="System Bold" size="16.0" />
                    </font>
                </Label>

                <Label layoutX="50.0" layoutY="168.0" text="Recent Payment Notifications:">
                    <font>
                        <Font size="14.0" />
                    </font>
                </Label>
                <TextArea fx:id="notificationsTextArea" editable="false" layoutX="50.0" layoutY="199.0" prefHeight="123.0" prefWidth="605.0" style="-fx-control-inner-background: #fdfdfd;" wrapText="true" />
            </children>
         <padding>
            <Insets right="30.0" />
         </padding>
        </AnchorPane>
    </center>
</BorderPane>
