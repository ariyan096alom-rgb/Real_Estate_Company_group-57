<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="400.0" prefWidth="550.0" style="-fx-background-color: #f4f7f6;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.real_estate_company.mahhi.SalesreportController">
    <children>
        <Label layoutX="193.0" layoutY="35.0" text="Sales Performance" textFill="#2c3e50">
            <font>
                <Font name="System Bold" size="22.0" />
            </font>
        </Label>

        <Label layoutX="80.0" layoutY="100.0" text="Select Report Period:" />
        <ComboBox fx:id="timeRangeComboBox" layoutX="210.0" layoutY="96.0" prefWidth="150.0" promptText="Select Period" />
        <Button layoutX="375.0" layoutY="96.0" onAction="#generateReportOnAction" style="-fx-background-color: #2980b9;" text="Generate" textFill="WHITE" />

        <Label fx:id="statusMessageLabel" alignment="CENTER" layoutX="75.0" layoutY="135.0" prefWidth="400.0" text="..." textFill="#7f8c8d" />

        <VBox alignment="CENTER" layoutX="75.0" layoutY="170.0" prefHeight="150.0" prefWidth="400.0" spacing="15.0" style="-fx-background-color: white; -fx-border-color: #dcdde1; -fx-border-radius: 10; -fx-background-radius: 10;">
            <children>
                <Label text="Total Sales Revenue">
                    <font>
                        <Font size="14.0" />
                    </font>
                </Label>
                <Label fx:id="totalRevenueLabel" text="BDT 0.00" textFill="#27ae60">
                    <font>
                        <Font name="System Bold" size="28.0" />
                    </font>
                </Label>
                <Label fx:id="unitsSoldLabel" text="0 Units Sold" textFill="#34495e">
                    <font>
                        <Font name="System Italic" size="16.0" />
                    </font>
                </Label>
            </children>
        </VBox>

        <Button layoutX="14.0" layoutY="14.0" onAction="#backToDashboardOnAction" text="&lt; Back" />
    </children>
</AnchorPane>
