<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.chart.PieChart?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="500.0" prefWidth="650.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.real_estate_company.mahhi.FinancialsummaryController">
    <children>
        <Label layoutX="216.0" layoutY="24.0" text="Financial Performance" textFill="#2c3e50">
            <font>
                <Font name="System Bold" size="20.0" />
            </font>
        </Label>

        <PieChart fx:id="incomeExpenseChart" layoutX="75.0" layoutY="74.0" prefHeight="334.0" prefWidth="500.0" title="Revenue vs Expenses" />

        <Button layoutX="255.0" layoutY="430.0" mnemonicParsing="false" onAction="#loadChartOnAction" prefHeight="30.0" prefWidth="140.0" style="-fx-background-color: #27ae60;" text="Load Chart Data" textFill="WHITE">
            <font>
                <Font name="System Bold" size="14.0" />
            </font>
        </Button>

        <Button layoutX="14.0" layoutY="14.0" mnemonicParsing="false" onAction="#backToDashboardOnAction" text="&lt; Back" />
    </children>
</AnchorPane>