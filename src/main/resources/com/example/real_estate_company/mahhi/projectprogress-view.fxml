<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="450.0" prefWidth="600.0" style="-fx-background-color: #f9f9f9;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.real_estate_company.mahhi.ProjectprogressController">
    <children>
        <Label layoutX="197.0" layoutY="25.0" text="Real Estate Project Progress" textFill="#2c3e50">
            <font>
                <Font name="System Bold" size="18.0" />
            </font>
        </Label>

        <TableView fx:id="projectTable" layoutX="50.0" layoutY="70.0" prefHeight="200.0" prefWidth="500.0">
            <columns>
                <TableColumn fx:id="nameColumn" prefWidth="280.0" text="Project Name" />
                <TableColumn fx:id="deadlineColumn" prefWidth="218.0" text="Expected Deadline" />
            </columns>
        </TableView>

        <Label layoutX="50.0" layoutY="290.0" text="Completion Status:">
            <font>
                <Font name="System Italic" size="13.0" />
            </font>
        </Label>

        <ProgressBar fx:id="taskProgressBar" layoutX="50.0" layoutY="315.0" prefHeight="30.0" prefWidth="400.0" progress="0.0" style="-fx-accent: #27ae60;" />

        <Label fx:id="percentageLabel" layoutX="465.0" layoutY="320.0" text="0% Complete" textFill="#27ae60">
            <font>
                <Font name="System Bold" size="14.0" />
            </font>
        </Label>

        <Button layoutX="243.0" layoutY="380.0" mnemonicParsing="false" onAction="#loadProjectsOnAction" prefHeight="30.0" prefWidth="115.0" style="-fx-background-color: #34495e;" text="Load Projects" textFill="WHITE">
            <font>
                <Font name="System Bold" size="12.0" />
            </font>
        </Button>

        <Button layoutX="14.0" layoutY="14.0" mnemonicParsing="false" onAction="#backToDashboardOnAction" text="&lt; Back" />
    </children>
</AnchorPane>
