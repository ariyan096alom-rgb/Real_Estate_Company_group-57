<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" style="-fx-background-color: #f4f4f4;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.real_estate_company.mahhi.SalarysummaryController">
    <children>
        <Label layoutX="193.0" layoutY="33.0" text="Employee Salary Summary" textFill="#2c3e50">
            <font>
                <Font name="System Bold" size="18.0" />
            </font>
        </Label>

        <ComboBox fx:id="monthComboBox" layoutX="108.0" layoutY="91.0" prefWidth="150.0" promptText="Select Month" />
        <Button layoutX="290.0" layoutY="91.0" mnemonicParsing="false" onAction="#loadSalaryOnAction" prefHeight="26.0" prefWidth="105.0" style="-fx-background-color: #3498db;" text="View Payroll" textFill="WHITE" />

        <Label layoutX="150.0" layoutY="160.0" text="Total Base Salary:">
            <font>
                <Font size="14.0" />
            </font>
        </Label>
        <Label fx:id="totalSalaryLabel" layoutX="320.0" layoutY="160.0" text="---" textFill="#2980b9">
            <font>
                <Font name="System Bold" size="14.0" />
            </font>
        </Label>

        <Label layoutX="150.0" layoutY="200.0" text="Total Bonuses:">
            <font>
                <Font size="14.0" />
            </font>
        </Label>
        <Label fx:id="bonusLabel" layoutX="320.0" layoutY="200.0" text="---" textFill="#2980b9">
            <font>
                <Font name="System Bold" size="14.0" />
            </font>
        </Label>

        <Label layoutX="150.0" layoutY="260.0" text="Grand Total Payroll:">
            <font>
                <Font name="System Bold" size="16.0" />
            </font>
        </Label>
        <Label fx:id="grandTotalLabel" layoutX="320.0" layoutY="260.0" text="---" textFill="#27ae60">
            <font>
                <Font name="System Bold" size="18.0" />
            </font>
        </Label>

        <Button layoutX="14.0" layoutY="14.0" mnemonicParsing="false" onAction="#backToDashboardOnAction" text="&lt; Back" />
    </children>
</AnchorPane>