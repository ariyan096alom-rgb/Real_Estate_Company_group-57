<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="500.0" prefWidth="750.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.real_estate_company.KaziTahmidAbtahi.Client.MyBookingsController">
    <children>
        <Label layoutX="65.0" layoutY="39.0" text="My Bookings" textFill="#2846bf">
            <font>
                <Font name="System Bold" size="20.0" />
            </font>
        </Label>

        <TableView fx:id="bookingsTableView" layoutX="40.0" layoutY="85.0" prefHeight="268.0" prefWidth="653.0">
            <columns>
                <TableColumn fx:id="bookingIdTC" prefWidth="124.79995346069336" text="Booking ID" />
                <TableColumn fx:id="propertyNameTC" prefWidth="220.80006408691406" text="Property Name" />
                <TableColumn fx:id="bookingDateTC" prefWidth="151.2000732421875" text="Date Submitted" />
                <TableColumn fx:id="statusTC" prefWidth="172.00006103515625" text="Status" />
            </columns>
        </TableView>
        
        <Label fx:id="feedbackLabel" layoutX="40.0" layoutY="385.0" prefHeight="63.0" prefWidth="381.0" style="-fx-background-color: #f0f0f0;" text="Feedback..........." textFill="#616161" />
      <Button layoutX="469.0" layoutY="404.0" mnemonicParsing="false" onAction="#provideDocumentInformationButtonOnAction" text="Provide Document Information" />
    </children>
</AnchorPane>
