<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="550.0" prefWidth="650.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.real_estate_company.KaziTahmidAbtahi.Client.PropertySearchController">
   <children>
      <Label layoutX="222.0" layoutY="29.0" text="Available Properties" textFill="#324dae" AnchorPane.topAnchor="29.0">
         <font>
            <Font name="System Bold" size="16.0" />
         </font>
      </Label>
      <Button layoutX="38.0" layoutY="219.0" mnemonicParsing="false" onAction="#filterPropertiesButtonOnAction" prefHeight="26.0" prefWidth="242.0" text="Filter Properties" />
      <ComboBox fx:id="locationCB" layoutX="203.0" layoutY="120.0" prefHeight="26.0" prefWidth="188.0" promptText="Location" />
      <TextField fx:id="maxPriceTF" layoutX="231.0" layoutY="83.0" prefHeight="26.0" prefWidth="188.0" promptText="Max Price" />
      <ComboBox fx:id="propertyTypeCB" layoutX="206.0" layoutY="161.0" prefHeight="26.0" prefWidth="188.0" promptText="Property Type" />
      <TableView fx:id="propertyDataTableView" layoutX="38.0" layoutY="250.0" prefHeight="219.0" prefWidth="587.0">
        <columns>
          <TableColumn fx:id="propertyIdTC" prefWidth="92.79999160766602" text="Property ID" />
          <TableColumn fx:id="propertyNameTC" prefWidth="100.0" text="Property Name" />
            <TableColumn fx:id="propertyLocationTC" prefWidth="84.00004577636719" text="Location" />
            <TableColumn fx:id="propertyPriceTC" prefWidth="85.5999755859375" text="Price" />
            <TableColumn fx:id="propertySizeTC" prefWidth="80.00006103515625" text="Size (sq ft)" />
            <TableColumn fx:id="propertyBedroomsTC" prefWidth="74.4000244140625" text="Bedrooms" />
            <TableColumn fx:id="propertyStatusTC" prefWidth="70.39996337890625" text="Status" />
        </columns>
      </TableView>
      <Button layoutX="421.0" layoutY="174.0" mnemonicParsing="false" onAction="#showPropertyDetailsButtonOnAction" prefHeight="58.0" prefWidth="174.0" text="Show Property Details" />
      <Label layoutX="38.0" layoutY="88.0" prefHeight="18.0" prefWidth="173.0" text="Enter Maximum Price Amount:" />
      <Label layoutX="38.0" layoutY="125.0" text="Enter Preffered Location:" />
      <Label layoutX="38.0" layoutY="166.0" text="Enter Preffered Property Type:" />
      <Button layoutX="38.0" layoutY="487.0" mnemonicParsing="false" onAction="#goBackToDashboardButtonOnAction" text="&lt;&lt;Go back to dashboard  " />
   </children>
</AnchorPane>
