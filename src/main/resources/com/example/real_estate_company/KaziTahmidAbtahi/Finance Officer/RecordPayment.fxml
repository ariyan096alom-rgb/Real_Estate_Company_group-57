<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="550.0" prefWidth="741.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.real_estate_company.KaziTahmidAbtahi.FinanceOfficer.VerifyDocumentsController">
    <children>
        <Label layoutX="80.0" layoutY="45.0" text="Record Client Payment" textFill="#4156b7">
            <font>
                <Font name="System Bold" size="20.0" />
            </font>
        </Label>
        <Label layoutX="78.0" layoutY="112.0" text="Select Client &amp; Booking:" />
        <ComboBox fx:id="clientBookingCB" layoutX="235.0" layoutY="106.0" prefWidth="250.0" />
        <Label layoutX="82.0" layoutY="149.0" text="Payment Type:" />
        <ComboBox fx:id="paymentTypeCB" layoutX="236.0" layoutY="151.0" prefWidth="250.0" />
        <Label layoutX="79.0" layoutY="200.0" text="Amount Received:" />
        <TextField fx:id="amountTF" layoutX="235.0" layoutY="196.0" prefWidth="250.0" />
        <Label layoutX="82.0" layoutY="245.0" text="Payment Date:" />
        <DatePicker fx:id="paymentDatePicker" layoutX="236.0" layoutY="241.0" prefWidth="250.0" />
        <Label layoutX="80.0" layoutY="286.0" text="Payment Method:" />
        <ComboBox fx:id="paymentMethodCB" layoutX="239.0" layoutY="286.0" prefWidth="250.0" />
        <Label layoutX="82.0" layoutY="335.0" text="Transaction Reference:" />
        <TextField fx:id="transactionRefTF" layoutX="239.0" layoutY="331.0" prefWidth="250.0" />
        <Button layoutX="84.0" layoutY="410.0" mnemonicParsing="false" onAction="#recordPaymentButtonOnAction" prefHeight="79.0" prefWidth="182.0" text="Record Payment &amp; Receipt" />
        <Label fx:id="feedbackLabel" layoutX="342.0" layoutY="389.0" prefHeight="121.0" prefWidth="280.0" style="-fx-background-color: light grey;" text="Feedback........." />
    </children>
</AnchorPane>
