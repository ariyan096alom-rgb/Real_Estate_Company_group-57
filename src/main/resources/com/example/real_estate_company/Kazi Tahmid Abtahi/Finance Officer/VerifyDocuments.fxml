<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="514.0" prefWidth="741.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.real_estate_company.KaziTahmidAbtahi.FinanceOfficer.VerifyDocumentsController">
    <children>
        <Label layoutX="105.0" layoutY="50.0" text="Verify Client Documents" textFill="#2f46b9">
            <font>
                <Font name="System Bold" size="20.0" />
            </font>
        </Label>
        <Label layoutX="105.0" layoutY="115.0" text="Select Pending Booking:" />
        <ComboBox fx:id="bookingSelectionCB" layoutX="260.0" layoutY="111.0" onAction="#loadDocumentDataOnAction" prefWidth="200.0" />
        <Label layoutX="105.0" layoutY="160.0" text="Client NID Number:" />
        <TextField fx:id="clientNidTF" editable="false" layoutX="260.0" layoutY="156.0" prefWidth="200.0" />
        <Label layoutX="105.0" layoutY="205.0" text="Client Income (BDT):" />
        <TextField fx:id="clientIncomeTF" editable="false" layoutX="260.0" layoutY="201.0" prefWidth="200.0" />
        <Label layoutX="105.0" layoutY="250.0" text="NID Verified?" />
        <ComboBox fx:id="nidVerifiedCB" layoutX="260.0" layoutY="246.0" prefWidth="100.0" promptText="Yes / No" />
        <Label layoutX="105.0" layoutY="295.0" text="Income Verified?" />
        <ComboBox fx:id="incomeVerifiedCB" layoutX="260.0" layoutY="291.0" prefWidth="100.0" promptText="Yes / No" />
        <Label layoutX="490.0" layoutY="160.0" text="Additional Notes:" />
        <TextArea fx:id="notesTextArea" layoutX="490.0" layoutY="185.0" prefHeight="130.0" prefWidth="200.0" />
        <Button layoutX="105.0" layoutY="350.0" mnemonicParsing="false" onAction="#submitVerificationButtonOnAction" prefHeight="30.0" prefWidth="200.0" text="Submit Verification Status" />
        <Label fx:id="feedbackLabel" layoutX="105.0" layoutY="400.0" prefHeight="50.0" prefWidth="585.0" style="-fx-background-color: light grey;" text="Feedback......" />
    </children>
</AnchorPane>