<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="550.0" prefWidth="741.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="KaziTahmidAbtahi.FinanceOfficer.InvoiceAndPaymentScheduleController">
    <children>
        <Label layoutX="79.0" layoutY="46.0" text="Generate Invoice and Payment Schedule" textFill="#3b368e">
            <font>
                <Font name="System Bold" size="20.0" />
            </font>
        </Label>
        <Label layoutX="81.0" layoutY="111.0" text="Select Approved Booking:" />
        <ComboBox fx:id="bookingCB" layoutX="269.0" layoutY="107.0" prefWidth="200.0" />

        <Label layoutX="80.0" layoutY="155.0" text="Down Payment % (10-30):" />
        <TextField fx:id="downPaymentTF" layoutX="269.0" layoutY="151.0" prefWidth="200.0" />

        <Label layoutX="81.0" layoutY="199.0" text="Number of Installments:" />
        <TextField fx:id="installmentsTF" layoutX="270.0" layoutY="196.0" prefWidth="200.0" />

        <Label layoutX="81.0" layoutY="245.0" text="Installment Frequency:" />
        <ComboBox fx:id="frequencyCB" layoutX="269.0" layoutY="243.0" prefWidth="200.0" />

        <Label layoutX="81.0" layoutY="290.0" text="Start Date:" />
        <DatePicker fx:id="startDatePicker" layoutX="269.0" layoutY="286.0" prefWidth="200.0" />

        <Button layoutX="495.0" layoutY="217.0" mnemonicParsing="false" onAction="#calculateScheduleButtonOnAction" prefHeight="40.0" prefWidth="127.0" text="Calculate Schedule" />

        <TextArea fx:id="previewTextArea" editable="false" layoutX="80.0" layoutY="340.0" prefHeight="100.0" prefWidth="554.0" />

        <Button layoutX="495.0" layoutY="279.0" mnemonicParsing="false" onAction="#generateInvoiceButtonOnAction" prefHeight="40.0" prefWidth="127.0" text="Save &amp; Generate" />
        <Label fx:id="feedbackLabel" layoutX="80.0" layoutY="449.0" prefHeight="68.0" prefWidth="378.0" style="-fx-background-color: light grey;" text="Feedback........." />
    </children>
</AnchorPane>
