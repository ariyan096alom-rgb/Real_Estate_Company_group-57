<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" style="-fx-background-color: #f4f5f7; -fx-border-color: #b28a47; -fx-border-width: 10;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="KaziTahmidAbtahi.Main.LoginController">
    <children>
        <Label alignment="CENTER" layoutX="213.0" layoutY="70.0" text="System Login" textFill="#2451ab">
            <font>
                <Font name="System Bold" size="26.0" />
            </font>
        </Label>

        <Label layoutX="175.0" layoutY="145.0" text="Email Address:" textFill="#333333" />
        <TextField fx:id="emailTextField" layoutX="175.0" layoutY="165.0" prefHeight="30.0" prefWidth="250.0" promptText="Enter your email" />

        <Label layoutX="175.0" layoutY="215.0" text="Password:" textFill="#333333" />
        <PasswordField fx:id="passwordField" layoutX="175.0" layoutY="235.0" prefHeight="30.0" prefWidth="250.0" promptText="Enter your password" />

        <Button layoutX="225.0" layoutY="295.0" mnemonicParsing="false" onAction="#loginButtonOnAction" prefHeight="35.0" prefWidth="150.0" style="-fx-background-color: #2f3e58;" text="Login" textFill="WHITE">
            <font>
                <Font name="System Bold" size="14.0" />
            </font>
        </Button>

        <Label fx:id="feedbackLabel" alignment="CENTER" layoutX="100.0" layoutY="355.0" prefHeight="20.0" prefWidth="400.0" textFill="#d31717">
            <font>
                <Font name="System Bold" size="12.0" />
            </font>
        </Label>
    </children>
</AnchorPane>