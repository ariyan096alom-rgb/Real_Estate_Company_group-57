<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="400" prefWidth="600" xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.real_estate_company.ZayedBinZaman.LeagalUser.AgreementController">
    <children>
        <VBox layoutX="50" layoutY="30" spacing="10">
            <Label text="Agreement" />
            <TextField fx:id="AgreementIdTextField" promptText="Agreement ID" />
            <TextField fx:id="ClientIdTextField" promptText="Client ID" />
            <TextField fx:id="propertyIdTextField" promptText="Property ID" />
            <Button onAction="#generateAgreementOnClick" text="Generate Agreement" />
            <Button onAction="#validateAgreementOnClick" text="Validate Agreement" />
            <TextArea fx:id="statusLabel" prefHeight="100" />
        </VBox>
    </children>
</AnchorPane>
