<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="545.0" prefWidth="619.0" xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.real_estate_company.ZayedBinZaman.SiteEngineer.MessageController">
    <children>
        <VBox layoutX="50" layoutY="30" spacing="10">
            <Label text="Message" />
            <TextField fx:id="messageID" promptText="Message ID" />
            <TextField fx:id="send" promptText="Sender" />
            <TextField fx:id="receiver" promptText="Receiver" />
            <TextArea fx:id="messageContant" promptText="Message Content" />
            <Button onAction="#SendOA" text="Send Message" />
            <TextArea fx:id="output" prefHeight="80" />
        </VBox>
    </children>
</AnchorPane>
