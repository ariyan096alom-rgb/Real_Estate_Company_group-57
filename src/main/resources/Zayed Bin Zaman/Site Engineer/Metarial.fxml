<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="400" prefWidth="600" xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.real_estate_company.MetrialController">
    <children>
        <VBox layoutX="50" layoutY="30" spacing="10">
            <Label text="Material" />
            <TextField fx:id="metarialID" promptText="Material ID" />
            <TextField fx:id="metarialName" promptText="Material Name" />
            <TextField fx:id="quantity" promptText="Quantity" />
            <Button onAction="#updateOA" text="Update Inventory" />
            <Button onAction="#trackOA" text="Track Usage" />
            <TextArea fx:id="output" prefHeight="100" />
        </VBox>
    </children>
</AnchorPane>
