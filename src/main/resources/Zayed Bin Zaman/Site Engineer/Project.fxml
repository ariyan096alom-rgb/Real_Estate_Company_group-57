<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="400" prefWidth="600" xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.real_estate_company.ZayedBinZaman.SiteEngineer.ProjectController">
    <children>
        <VBox layoutX="50" layoutY="30" spacing="10">
            <Label text="Project" />
            <TextField fx:id="project" promptText="Project ID" />
            <TextField fx:id="name" promptText="Project Name" />
            <TextField fx:id="progress" promptText="Progress" />
            <Button onAction="#defineOA" text="Define Project" />
            <Button onAction="#updateOA" text="Update Timeline" />
            <TextArea fx:id="output" prefHeight="100" />
        </VBox>
    </children>
</AnchorPane>
